{
    "name":  "projects",
    "version":  "1.0.0",
    "description":  "Vanilla TypeScript application with Express + Vite (HTML + CSS + TS + Node API)",
    "scripts":  {
                    "build":  "vite build",
                    "dev":  "node scripts/dev.mjs",
                    "preinstall":  "npx only-allow pnpm",
                    "postinstall":  "node scripts/patch-react-swc.cjs",
                    "lint":  "eslint",
                    "lint:build":  "eslint . --quiet",
                    "start":  "node dist-server/server.js",
                    "ts-check":  "tsc -p tsconfig.json",
                    "validate":  "pnpm run --parallel \u0027/^(ts-check|lint:build)$/\u0027"
                },
    "dependencies":  {
                         "@supabase/supabase-js":  "2.95.3",
                         "dotenv":  "^17.2.3",
                         "express":  "^4.21.2",
                         "react":  "^19.2.7",
                         "react-dom":  "^19.2.7"
                     },
    "devDependencies":  {
                            "@types/express":  "^5.0.0",
                            "@types/node":  "^22.10.5",
                            "@types/react":  "^19.2.17",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react-swc":  "4",
                            "autoprefixer":  "^10.4.20",
                            "coze-coding-dev-sdk":  "^0.7.24",
                            "esbuild":  "^0.24.2",
                            "eslint":  "^9",
                            "eslint-plugin-import":  "^2.32.0",
                            "only-allow":  "^1.2.2",
                            "postcss":  "^8.4.49",
                            "tailwindcss":  "^3.4.17",
                            "tsup":  "^8.3.5",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.6.0",
                            "typescript-eslint":  "^8",
                            "vite":  "^7.2.4",
                            "vite-plugin-pwa":  "^1.3.0"
                        },
    "packageManager":  "pnpm@9.0.0",
    "engines":  {
                    "pnpm":  "\u003e=9.0.0"
                },
    "pnpm":  {
                 "overrides":  {
                                   "esbuild":  "^0.27.2",
                                   "is-generator-function":  "1.0.10"
                               }
             }
}